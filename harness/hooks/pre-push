#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

CHANGED_FILES_PATH="harness/reports/pre-push-changed-files.txt"
mkdir -p "harness/reports"
: > "$CHANGED_FILES_PATH"

while read local_ref local_sha remote_ref remote_sha
do
  zero_sha="0000000000000000000000000000000000000000"

  if [ -z "$local_sha" ] || [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero_sha" ]; then
    git diff-tree --no-commit-id --name-only -r "$local_sha" >> "$CHANGED_FILES_PATH" || true
  else
    git diff --name-only "$remote_sha..$local_sha" >> "$CHANGED_FILES_PATH" || true
  fi
done

sort -u "$CHANGED_FILES_PATH" -o "$CHANGED_FILES_PATH"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "./harness/run-harness.ps1" -Mode gate -RunBuild -RunDb -ChangedFilesPath "$CHANGED_FILES_PATH"
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "./harness/run-harness.ps1" -Mode gate -RunBuild -RunDb -ChangedFilesPath "$CHANGED_FILES_PATH"
else
  echo "PCS pre-push failed: PowerShell runner was not found."
  echo "Install PowerShell 7+."
  echo "macOS: brew install --cask powershell"
  exit 1
fi
