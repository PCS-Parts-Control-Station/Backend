#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "./harness/run-harness.ps1" -Mode full -RunBuild -RunDb
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "./harness/run-harness.ps1" -Mode full -RunBuild -RunDb
else
  echo "PCS pre-push failed: PowerShell runner was not found."
  echo "Install PowerShell 7+."
  echo "macOS: brew install --cask powershell"
  exit 1
fi
