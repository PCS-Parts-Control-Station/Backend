#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "./harness/run-harness.ps1" -Mode bootstrap
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "./harness/run-harness.ps1" -Mode bootstrap
fi
