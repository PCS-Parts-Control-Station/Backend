<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pcs.global.mapper.PartUnitConditionSql">

    <sql id="activeInStock">
        u.active = TRUE
        AND u.unit_status = 'IN_STOCK'
    </sql>

    <sql id="salesHold">
        <include refid="com.pcs.global.mapper.PartUnitConditionSql.activeInStock" />
        AND u.sales_status = 'HOLD'
    </sql>

    <sql id="salesUnavailable">
        <include refid="com.pcs.global.mapper.PartUnitConditionSql.activeInStock" />
        AND u.sales_status = 'UNAVAILABLE'
    </sql>

</mapper>
